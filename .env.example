# Resend — envoi des emails du formulaire de contact
# Crée une clé API sur https://resend.com/api-keys
RESEND_API_KEY=

# Adresse "from" affichée comme expéditeur.
# Laisse vide pour utiliser le domaine de test Resend (onboarding@resend.dev),
# qui ne peut livrer qu'à l'adresse du propriétaire du compte Resend.
# Pour envoyer depuis ton domaine, vérifie-le sur Resend puis renseigne par ex. :
# CONTACT_FROM_EMAIL=Portfolio <contact@tondomaine.fr>
CONTACT_FROM_EMAIL=

# Adresse qui reçoit les messages (par défaut lucval1701@gmail.com)
CONTACT_TO_EMAIL=
